{
  "name": "page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:search-index && next dev",
    "build": "npm run generate:resume-assets && npm run build:search-index && next build",
    "build:full": "npm run generate:resume-assets && npm run generate:projects && node scripts/generate-github-projects.mjs && npm run build:search-index && next build",
    "export": "echo \"Export handled during \"next build\" when \"output: 'export'\" is set in next.config.js\"",
    "start": "next start",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx --config ./config/eslint.config.mjs .",
    "typecheck": "tsc --noEmit",
    "validate:content-images": "node ./scripts/validate-content-images.js",
    "validate:frontmatter": "npm exec -- tsx ./scripts/validate-content-frontmatter.ts",
    "build:search-index": "npm exec -- tsx ./scripts/build-search-index.ts",
    "precommit": "npm run typecheck && npm run lint && npm run validate:content-images && npm run validate:frontmatter && npm test",
    "ci:check": "npm run lint && npm run build && npm run build:search-index && npm run validate:validate-content-images",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "fetch-scholar": "node ./scripts/fetch-scholar.js",
    "ci:fetch-publications": "npm run fetch-scholar",
    "generate:projects": "node scripts/generate-github-projects.mjs",
    "generate:resumes": "npx tsx scripts/generate-json-resume.ts",
    "generate:resume-pdfs": "npx tsx scripts/generate-pdf-snapshots.ts",
    "generate:resume-assets": "npm run generate:resumes && npm run generate:resume-pdfs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/three": "^0.180.0",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.23.12",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.0.1",
    "katex": "^0.16.11",
    "lucide-react": "^0.540.0",
    "next": "15.5.0",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^6.1.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1",
    "shiki": "^0.14.0",
    "three": "^0.180.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.4.14",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "node-fetch": "^3.3.0",
    "postcss": "^8.4.23",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}